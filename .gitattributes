# Git LFS tracking configuration
# Built_in_DoS_attack.pcap is 61.2 MB — exceeds GitHub's 50 MB per-file recommendation.
# It is tracked via Git LFS automatically when you push.

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

# Track the large DoS file via LFS
*.pcap filter=lfs diff=lfs merge=lfs -text

# Track all pcapng files via LFS as well (future-proofing)
*.pcapng filter=lfs diff=lfs merge=lfs -text
